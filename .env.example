# Supabase Configuration
# Copy this file to .env.local and fill in your values
#
# QA environment: use your QA Supabase project credentials
# Production environment: use your Production Supabase project credentials
# Vercel will use environment variables set in the dashboard per environment

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (for admin scripts only — never exposed to browser)
# Find at: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
